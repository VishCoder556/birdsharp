#!include "std.bsh"

int main() {
    char* secret = "Birdsharp!";
    long addr = cast(long, secret);
    
    int i = 0;
    while (i < 10) {
        int val = cast(int, deref(cast(char*, addr + cast(long, i))));
        print_hex_byte(val);
        print(" ");
        i = i + 1;
    }
    print("\n");
    return 0;
}
