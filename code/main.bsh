#!semicolon
#!autovar
#!include "std.bsh"

long fibonacci(long n) {
    if (n < 2) {
        return n
    };
    long a = 0;
    long b = 1;
    long i = 2;
    long temp = 0;
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}

i32 main(i32 argc, char **argv){
    return 0;
}
