#!include "std.bsh"
long fibonacci(long n) {
    if (n < 2) {
        return n
    }
    long a = 0;
    long b = 1;
    long i = 2;
    long temp = 0;
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}


int main(long argc, char **argv) {
    int[10] a
    a[0] = 5
    a[1] = 10
    a[2] = 15
    exit((a[0] + a[1] * a[2]))
    return 0;
}
