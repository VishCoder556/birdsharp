#!include "../code/std.bsh"
#!autovar on

var fibonacci(var n) {
    if (n < 2) {
        return n
    }
    a = 0;
    b = 1;
    i = 2;
    temp = 0;
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}

#!flat
print("Fibonacci(10) = ")
print(long_to_string(fibonacci(10)))
print("\n")
return 0;
