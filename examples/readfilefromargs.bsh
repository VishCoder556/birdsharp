#!include "../code/std.bsh"

int main(long argc, char **argv){
    if (argc <= cast(long, 1)){
        printerr("ERROR: Not enough arguments\n");
    }

    char *str1 = deref(argv + cast(long, 8))

    int fd = syscall.open(str1, 0, 0);
    if (fd == 0){
        print("Error\n")
    }
    char *str = cast(char*, malloc(cast(long, 2000)));
    syscall.read(fd, str, 2000)
    print(str);
    syscall.exit(fd);
    return 0
}

