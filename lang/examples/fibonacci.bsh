#!include "std.bsh"

i64 fibonacci(i64 n) {
    if (n < 2) {
        return n
    }
    i64 a = 0;
    i64 b = 1;
    i64 i = 2;
    i64 temp = 0;
    
    while (i <= n) {
        temp = a + b;
        a = b;
        b = temp;
        i = i + 1;
    }
    return b;
}


i32 main(i64 argc, char **argv) {
    print("Fibonacci(10) = ")
    print(long_to_string(fibonacci(10)))
    print("\n")
    exit(0)
    return 0;
}
